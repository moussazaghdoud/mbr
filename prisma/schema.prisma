generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// SharePoint connection configuration
model SyncConfig {
  id                String   @id @default("default")
  siteUrl           String   @default("")
  driveId           String   @default("")
  folderPath        String   @default("/")
  filePattern       String   @default("*.xlsx")
  pollingIntervalMin Int     @default(30)
  enabled           Boolean  @default(false)
  lastTestedAt      DateTime?
  connectionStatus  String   @default("unknown")
  username          String   @default("")
  password          String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SyncJob {
  id            String        @id @default(cuid())
  status        String        @default("pending")
  startedAt     DateTime      @default(now())
  completedAt   DateTime?
  totalFiles    Int           @default(0)
  filesProcessed Int          @default(0)
  filesFailed   Int           @default(0)
  rowsImported  Int           @default(0)
  rowsUpdated   Int           @default(0)
  rowsRejected  Int           @default(0)
  errorMessage  String?
  triggeredBy   String        @default("manual")
  fileLogs      SyncFileLog[]
}

model SyncFileLog {
  id           String   @id @default(cuid())
  syncJobId    String
  syncJob      SyncJob  @relation(fields: [syncJobId], references: [id], onDelete: Cascade)
  fileName     String
  filePath     String
  fileSize     Int      @default(0)
  lastModified DateTime?
  eTag         String?
  status       String   @default("pending")
  rowsFound    Int      @default(0)
  rowsImported Int      @default(0)
  rowsRejected Int      @default(0)
  errorMessage String?
  processingMs Int      @default(0)
  createdAt    DateTime @default(now())
}

model ColumnMapping {
  id           String @id @default(cuid())
  profileName  String @default("default")
  excelColumn  String
  kpiId        String
  kpiField     String @default("value")
  transform    String @default("none")
  defaultValue String?
  required     Boolean @default(false)
}

model FileSyncCache {
  id           String   @id @default(cuid())
  filePath     String   @unique
  fileName     String
  eTag         String?
  lastModified DateTime?
  checksum     String?
  lastSyncedAt DateTime
  updatedAt    DateTime @updatedAt
}

model SyncedKPI {
  id               String   @id
  name             String
  domain           String
  value            String
  unit             String   @default("")
  period           String   @default("")
  target           String?
  targetUnit       String?
  variance         String?
  varianceDirection String?
  gap              String?
  sourceFile       String?
  sourceSheet      String?
  sourceRow        Int?
  syncedAt         DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Stores raw Excel data — every row from every sheet
model UploadedSheet {
  id         String   @id @default(cuid())
  fileName   String
  sheetName  String
  headers    String   // JSON array of column names
  rows       String   // JSON array of row objects
  rowCount   Int      @default(0)
  uploadedAt DateTime @default(now())

  @@unique([fileName, sheetName])
}
