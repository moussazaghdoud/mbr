# =====================================================
# CES MBR Portal — SharePoint Sync Configuration
# =====================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# --- Database ---
DATABASE_URL="file:./dev.db"

# --- SharePoint Authentication ---
# Choose auth mode: "ropc" (username/password) or "client_credentials" (app-only)
SHAREPOINT_AUTH_MODE="ropc"

# Azure AD / Entra ID
SHAREPOINT_TENANT_ID="your-azure-tenant-id"
SHAREPOINT_CLIENT_ID="your-app-client-id"

# For ROPC mode (username/password login)
SHAREPOINT_USERNAME="your.email@company.com"
SHAREPOINT_PASSWORD="your-password"

# For Client Credentials mode (app-only, no user password needed)
SHAREPOINT_CLIENT_SECRET="your-client-secret"

# --- SharePoint Site ---
SHAREPOINT_SITE_URL="https://yourcompany.sharepoint.com/sites/YourSite"
SHAREPOINT_DRIVE_ID=""
SHAREPOINT_FOLDER_PATH="/General/Reports"

# --- Sync Settings ---
SYNC_POLLING_INTERVAL_MINUTES="30"
SYNC_ENABLED="true"
